# Terraform state files - contains sensitive resource info, never commit these
terraform.tfstate
terraform.tfstate.backup
terraform.tfstate.d/

# tfvars - contains sensitive values like key names, credentials
terraform.tfvars
*.tfvars

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# SSH keys
*.pem
*.key

# OS files
.DS_Store
Thumbs.db
